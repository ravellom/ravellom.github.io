generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  datasets      Dataset[] @relation("DatasetCreator")
  chartConfigs  ChartConfig[] @relation("ChartConfigCreator")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  datasets    Dataset[]
  chartConfigs ChartConfig[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  activeDatasetId String?
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeDataset Dataset? @relation("ActiveDataset", fields: [activeDatasetId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
}

model Dataset {
  id           String   @id @default(cuid())
  workspaceId  String
  createdById  String
  name         String
  description  String?
  format       String   @default("csv")
  rowCount     Int      @default(0)
  columnCount  Int      @default(0)
  columns      Json?
  data         Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User      @relation("DatasetCreator", fields: [createdById], references: [id], onDelete: Cascade)
  activeForMembers WorkspaceMember[] @relation("ActiveDataset")

  @@index([workspaceId, createdAt])
}

model ChartConfig {
  id           String   @id @default(cuid())
  workspaceId  String
  createdById  String
  module       String
  title        String
  config       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User      @relation("ChartConfigCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, module, createdAt])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}
